\n              <img id=\"pic\" src=\"../../Assets/bio_pic.JPG\" alt=\"Photo of Josh Wilson\"></img>\n            </div>\n            <div className=\"col-md-9\">\n              <h1 className=\"display-8\">Hello, my name is Josh Wilson.</h1>\n              <p className=\"lead\">I'm currently studying to become a full-stack web developer at the UT Austin Coding\n                Bootcamp. My previous career was in audio engineering for commercials and film. In my spare time, I\n                enjoy homebrewing and playing hockey.</p>\n            </div>\n          </div>\n        </div>\n      </div>\n    </section>\n  );\n}\n\nexport default Jumbotron;\n","/Users/pony4/Desktop/jw_coding/homework/react-portfolio/src/components/PortfolioPiece/PortfolioPiece.js",["49","50"],"import React from \"react\";\n// import \"./style.css\";\n\n\n\nfunction PortfolioPiece(props) {\n  \n  return(\n    <div className=\"row\">\n      <div className=\"col-md-6\">\n        <h2>{props.title}</h2>\n        <img className=\"portfolio-image\" src={props.image} alt={props.alt}></img>\n        <p className=\"project-description\">{props.description}</p>\n        <a className=\"btn btn-dark\" href={props.github} target=\"_blank\"\n        role=\"button\">GitHub Repo</a>\n        <a className=\"btn btn-dark btn-right\" href={props.deployed}\n        target=\"_blank\" role=\"button\">Deployed Site</a>\n        <div className=\"portfolio-padding\"></div>\n      </div>\n    </div>\n  );\n}\n\nexport default PortfolioPiece;","/Users/pony4/Desktop/jw_coding/homework/react-portfolio/src/components/Footer/Footer.js",["51","52","53","54"],"import React from \"react\";\n// import \"./style.css\";\n\nfunction Footer(){\n  return(\n    <footer>\n    <nav className=\"navbar navbar-dark bg-dark fixed-bottom\">\n      <ul className=\"list-group list-group-horizontal nav navbar-nav\">\n        <li className=\"nav-item\">\n          <a className=\"nav-link\" href=\"https://www.linkedin.com/in/joshwilsonsound/\" target=\"_blank\">LinkedIn</a>\n        </li>\n        <li className=\"nav-item\">\n          <a className=\"nav-link\" href=\"https://vimeo.com/joshwilsonsound\" target=\"_blank\">Vimeo</a>\n        </li>\n        <li className=\"nav-item\">\n          <a className=\"nav-link\" href=\"https://github.com/josh-wilson6289\" target=\"_blank\">GitHub</a>\n        </li>\n        <li className=\"nav-item\">\n          <a className=\"nav-link\" href=\"./Assets/Sample Resume.pdf\" target=\"_blank\">Resume</a>\n        </li>\n      </ul>\n    </nav>\n  </footer>\n  );\n}\n\nexport default Footer;",{"ruleId":"55","replacedBy":"56"},{"ruleId":"57","replacedBy":"58"},{"ruleId":"59","severity":1,"message":"60","line":12,"column":15,"nodeType":"61","endLine":12,"endColumn":87},{"ruleId":"62","severity":1,"message":"63","line":14,"column":57,"nodeType":"64","endLine":14,"endColumn":72},{"ruleId":"62","severity":1,"message":"63","line":17,"column":9,"nodeType":"64","endLine":17,"endColumn":24},{"ruleId":"65","severity":1,"message":"66","line":4,"column":10,"nodeType":"67","messageId":"68","endLine":4,"endColumn":16},{"ruleId":"62","severity":1,"message":"63","line":10,"column":87,"nodeType":"64","endLine":10,"endColumn":102},{"ruleId":"62","severity":1,"message":"63","line":13,"column":76,"nodeType":"64","endLine":13,"endColumn":91},{"ruleId":"62","severity":1,"message":"63","line":16,"column":77,"nodeType":"64","endLine":16,"endColumn":92},"no-native-reassign",["69"],"no-negated-in-lhs",["70"],"jsx-a11y/img-redundant-alt","Redundant alt attribute. Screen-readers already announce `img` tags as an image. You don’t need to use the words `image`, `photo,` or `picture` (or any specified custom words) in the alt prop.","JSXOpeningElement","react/jsx-no-target-blank","Using target=\"_blank\" without rel=\"noreferrer\" is a security risk: see https://html.spec.whatwg.org/multipage/links.html#link-type-noopener","JSXAttribute","no-unused-vars","'Footer' is defined but never used.","Ide